{
  "model": {
    "name_or_path": "Qwen/Qwen2.5-7B-Instruct",
    "trust_remote_code": true,
    "quantization": "4bit"
  },
  "data": {
    "train_path": "data/processed/ade_sft_train.sample.jsonl",
    "eval_path": "evals/ade_eval_smoke.jsonl",
    "max_length": 2048
  },
  "lora": {
    "enabled": true,
    "r": 16,
    "alpha": 32,
    "dropout": 0.05,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ]
  },
  "training": {
    "output_dir": "outputs/qwen2.5-7b-ade-sft",
    "num_train_epochs": 1,
    "learning_rate": 2e-4,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 8,
    "warmup_ratio": 0.03,
    "weight_decay": 0.01,
    "logging_steps": 5,
    "save_strategy": "epoch",
    "bf16": false,
    "fp16": false,
    "gradient_checkpointing": true
  }
}

